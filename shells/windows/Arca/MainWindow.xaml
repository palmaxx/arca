<Window
    x:Class="Arca.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="Root" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Keyboard map (Day 0): Space pause, arrows seek/volume, M mute, F11 fullscreen -->
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="Space" Invoked="OnAccelTogglePause" />
            <KeyboardAccelerator Key="Left" Invoked="OnAccelSeekBack" />
            <KeyboardAccelerator Key="Right" Invoked="OnAccelSeekForward" />
            <KeyboardAccelerator Key="Left" Modifiers="Shift" Invoked="OnAccelSeekBackLong" />
            <KeyboardAccelerator Key="Right" Modifiers="Shift" Invoked="OnAccelSeekForwardLong" />
            <KeyboardAccelerator Key="Up" Invoked="OnAccelVolumeUp" />
            <KeyboardAccelerator Key="Down" Invoked="OnAccelVolumeDown" />
            <KeyboardAccelerator Key="M" Invoked="OnAccelToggleMute" />
            <KeyboardAccelerator Key="F11" Invoked="OnAccelToggleFullscreen" />
        </Grid.KeyboardAccelerators>

        <MenuBar Grid.Row="0" x:Name="AppMenuBar">
            <MenuBarItem Title="File">
                <MenuFlyoutItem Text="Open…" Click="OnOpenFile">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Key="O" Modifiers="Control" />
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="Exit" Click="OnExit" />
            </MenuBarItem>
        </MenuBar>

        <Grid Grid.Row="1" Background="Black">
            <SwapChainPanel x:Name="VideoPanel"
                            SizeChanged="OnPanelSizeChanged"
                            CompositionScaleChanged="OnPanelScaleChanged" />
            <TextBlock x:Name="IdleHint"
                       Text="File → Open…  (Ctrl+O)"
                       Foreground="#666"
                       FontSize="18"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
        </Grid>

        <Grid Grid.Row="2" x:Name="TransportBar" Padding="12,8" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" x:Name="PlayPauseButton" Click="OnPlayPause"
                    Width="44" IsEnabled="False">
                <FontIcon x:Name="PlayPauseIcon" Glyph="&#xE768;" />
            </Button>

            <TextBlock Grid.Column="1" x:Name="PositionText" Text="--:--"
                       VerticalAlignment="Center" FontFamily="Consolas" />

            <Slider Grid.Column="2" x:Name="SeekSlider"
                    Minimum="0" Maximum="100" StepFrequency="0.1"
                    IsEnabled="False" VerticalAlignment="Center"
                    ValueChanged="OnSeekSliderChanged" />

            <TextBlock Grid.Column="3" x:Name="DurationText" Text="--:--"
                       VerticalAlignment="Center" FontFamily="Consolas" />

            <Button Grid.Column="4" x:Name="MuteButton" Click="OnToggleMute" Width="44">
                <FontIcon x:Name="MuteIcon" Glyph="&#xE767;" />
            </Button>
        </Grid>
    </Grid>
</Window>
