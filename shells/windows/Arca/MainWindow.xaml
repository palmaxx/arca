<Window
    x:Class="Arca.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="Root" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Keyboard map (Day 0): Space pause, arrows seek/volume, M mute, F11 fullscreen -->
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="Space" Invoked="OnAccelTogglePause" />
            <KeyboardAccelerator Key="Left" Invoked="OnAccelSeekBack" />
            <KeyboardAccelerator Key="Right" Invoked="OnAccelSeekForward" />
            <KeyboardAccelerator Key="Left" Modifiers="Shift" Invoked="OnAccelSeekBackLong" />
            <KeyboardAccelerator Key="Right" Modifiers="Shift" Invoked="OnAccelSeekForwardLong" />
            <KeyboardAccelerator Key="Up" Invoked="OnAccelVolumeUp" />
            <KeyboardAccelerator Key="Down" Invoked="OnAccelVolumeDown" />
            <KeyboardAccelerator Key="M" Invoked="OnAccelToggleMute" />
            <KeyboardAccelerator Key="F11" Invoked="OnAccelToggleFullscreen" />
        </Grid.KeyboardAccelerators>

        <MenuBar Grid.Row="0" x:Name="AppMenuBar">
            <MenuBarItem Title="File">
                <MenuFlyoutItem Text="Open…" Click="OnOpenFile">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Key="O" Modifiers="Control" />
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="Exit" Click="OnExit" />
            </MenuBarItem>
            <MenuBarItem Title="Library">
                <MenuFlyoutItem Text="Add library…" Click="OnAddLibrary" />
                <MenuFlyoutItem Text="Rescan selected" Click="OnRescanLibrary" />
                <MenuFlyoutItem Text="Remove selected" Click="OnRemoveLibrary" />
                <MenuFlyoutSeparator />
                <ToggleMenuFlyoutItem x:Name="SidebarToggle" Text="Show sidebar"
                                      IsChecked="True" Click="OnToggleSidebar" />
            </MenuBarItem>
        </MenuBar>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarColumn" Width="300" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid x:Name="Sidebar" Grid.Column="0" Padding="8" RowSpacing="8"
                  Background="{ThemeResource LayerFillColorDefaultBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Libraries" FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <Button Grid.Column="1" Content="Add…" Click="OnAddLibrary" />
                </Grid>

                <ListView Grid.Row="1" x:Name="LibraryList" MaxHeight="220"
                          SelectionChanged="OnLibrarySelected">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Glyph="{Binding ModeGlyph}" FontSize="14"
                                          VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{Binding Display}"
                                           TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <TextBlock Grid.Row="2" x:Name="LibraryStatus" Foreground="#888"
                           TextWrapping="Wrap" />

                <ListView Grid.Row="3" x:Name="MediaList"
                          DoubleTapped="OnMediaDoubleTapped">
                    <ListView.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Key}" FontWeight="SemiBold" />
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ListView.GroupStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Display}"
                                       TextTrimming="CharacterEllipsis" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <Grid Grid.Column="1" Background="Black">
                <SwapChainPanel x:Name="VideoPanel"
                                SizeChanged="OnPanelSizeChanged"
                                CompositionScaleChanged="OnPanelScaleChanged" />
                <TextBlock x:Name="IdleHint"
                           Text="File → Open…  (Ctrl+O)   ·   Library → Add library…"
                           Foreground="#666"
                           FontSize="18"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Grid>
        </Grid>

        <Grid Grid.Row="2" x:Name="TransportBar" Padding="12,8" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" x:Name="PlayPauseButton" Click="OnPlayPause"
                    Width="44" IsEnabled="False">
                <FontIcon x:Name="PlayPauseIcon" Glyph="&#xE768;" />
            </Button>

            <TextBlock Grid.Column="1" x:Name="PositionText" Text="--:--"
                       VerticalAlignment="Center" FontFamily="Consolas" />

            <Slider Grid.Column="2" x:Name="SeekSlider"
                    Minimum="0" Maximum="100" StepFrequency="0.1"
                    IsEnabled="False" VerticalAlignment="Center"
                    ValueChanged="OnSeekSliderChanged" />

            <TextBlock Grid.Column="3" x:Name="DurationText" Text="--:--"
                       VerticalAlignment="Center" FontFamily="Consolas" />

            <Button Grid.Column="4" x:Name="MuteButton" Click="OnToggleMute" Width="44">
                <FontIcon x:Name="MuteIcon" Glyph="&#xE767;" />
            </Button>
        </Grid>
    </Grid>
</Window>
