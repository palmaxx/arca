{
  "version": 6,
  "configurePresets": [
    {
      "name": "win-x64-release",
      "displayName": "Windows x64 Release (MSVC + Ninja)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_COMPILER": "cl",
        "CMAKE_CXX_COMPILER": "cl"
      }
    },
    {
      "name": "win-x64-debug",
      "displayName": "Windows x64 Debug (MSVC + Ninja)",
      "inherits": "win-x64-release",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    }
  ],
  "buildPresets": [
    { "name": "win-x64-release", "configurePreset": "win-x64-release" },
    { "name": "win-x64-debug", "configurePreset": "win-x64-debug" }
  ]
}
